# Configuración del Servicio AFIP
# Copiar este archivo a .env y completar con tus datos

# ==========================================
# CONFIGURACIÓN OBLIGATORIA
# ==========================================

# CUIT del emisor (sin guiones)
# Ejemplo: AFIP_CUIT=30661465583
AFIP_CUIT=

# Punto de venta (número entero)
AFIP_PTO_VTA=1

# JWT Secret Key (generar con: openssl rand -hex 32)
# Esta clave es importante para la seguridad
JWT_SECRET_KEY=change-this-secret-key-in-production

# Certificados AFIP Homologación (ajustar nombres según tus archivos)
CERT_PATH=certs/homo/LIROpriv20260219homo2_crt.crt
KEY_PATH=certs/homo/LIROpriv20260219homo2.key

# Certificados AFIP Producción (ajustar nombres según tus archivos)
PROD_CERT_PATH=certs/prod/LIROPRUEBASFACT20260919PROD2_4d6fbf9ef97dc5b6.crt
PROD_KEY_PATH=certs/prod/LIROpriv20260219prod2.key

# ==========================================
# CONFIGURACIÓN OPCIONAL
# ==========================================

# Puerto donde escuchará el servicio (default: 8000)
API_PORT=8000

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ==========================================
# URLS AFIP (Homologación por defecto)
# ==========================================

# Descomentar para producción:
# URL_WSAA=https://wsaa.afip.gov.ar/ws/services/LoginCms?wsdl
# URL_WSFEV1=https://servicios1.afip.gov.ar/wsfev1/service.asmx?WSDL

# Homologación (testing):
URL_WSAA=https://wsaahomo.afip.gov.ar/ws/services/LoginCms?wsdl
URL_WSFEV1=https://wswhomo.afip.gov.ar/wsfev1/service.asmx?WSDL
