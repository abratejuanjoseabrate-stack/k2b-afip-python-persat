# Copiá este archivo como .env (mismo directorio) y completá valores
#
# Ejemplo:
#   Copy-Item .env.example .env
#
# CUIT del contribuyente (solo números, sin guiones)
CUIT=

# Punto de venta a consultar en CompUltimoAutorizado
PTO_VTA=1

# Tipo de comprobante a consultar en CompUltimoAutorizado
# Ejemplos:
#   1 = Factura A
#   6 = Factura B
#  11 = Factura C
TIPO_CBTE=6
